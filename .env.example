# ── Unicity network (testnet2) ──────────────────────────────────────────────
# Leave as-is for the public testnet2 gateway. The oracle key below is the
# documented public testnet2 key (NOT a secret).
SPHERE_NETWORK=testnet2
# SPHERE_ORACLE_API_KEY=sk_...
# SPHERE_WALLET_API_URL=https://wallet-api.unicity.network

# ── Escrow agent wallet ──────────────────────────────────────────────────────
# The platform's autonomous escrow agent. If BAZAAR_ESCROW_MNEMONIC is unset, a
# new wallet is generated on first boot and written to data/escrow/mnemonic.txt
# (gitignored) — copy it here, then delete the file. TESTNET ONLY.
BAZAAR_ESCROW_NAMETAG=bazaar-escrow-knkchn
# BAZAAR_ESCROW_MNEMONIC=word1 word2 ... word12

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4600
# Minutes a delivered job waits before auto-releasing to the provider.
BAZAAR_AUTO_RELEASE_MINUTES=2
